# aad-bridged configuration.
# Copy to `aad-bridge.env` (auto-loaded from the current directory) or to /etc/aad-bridge/aad-bridge.env for the systemd unit.
# Lines are KEY=value (systemd EnvironmentFile format). Precedence: CLI flags > real environment > this file.
#
# IMPORTANT: put comments on their OWN lines.
# An inline comment after a value (e.g. `AUDIT_LOG=/var/log/a.log  # note`) becomes PART of the value under systemd, which does not strip it.
# (The daemon's own loader is forgiving and strips it, but keep comments separate so the same file works under systemd too.)
#
# Value expansion (applied by the daemon when it loads this file):
#   ~ / ~/path      -> the daemon user's home directory
#   $VAR / ${VAR}   -> an environment variable (unset -> empty)
# e.g. AZURE_CONFIG_DIR=~/.azure  or  AUDIT_LOG=${HOME}/aad-bridge/audit.log
#
# Windows paths: use the native form, e.g. AUDIT_LOG=C:\ProgramData\aad-bridge\audit.log
# Backslashes are kept literally; quote a path that contains spaces:
#   TLS_CERT="C:\Program Files\aad-bridge\server.crt"

# --- Listener ---
PORT=8765
HOST=127.0.0.1

# --- Caller auth (pick at least one of SECRET or TLS_CLIENT_CA) ---
# Shared bearer secret. Generate with: openssl rand -base64 32
SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
# DEV ONLY (CLI: --insecure-no-auth) — disables caller auth:
# ALLOW_NO_AUTH=1

# --- TLS (strongly recommended; tokens are bearer credentials) ---
# Point these at your internal-CA-issued cert, or a self-signed one for testing. Omit to use plain HTTP.
TLS_CERT=/etc/aad-bridge/server.crt
TLS_KEY=/etc/aad-bridge/server.key
# Enable mTLS (per-machine client certs):
# TLS_CLIENT_CA=/etc/aad-bridge/clients-ca.pem

# --- Scope protection ---
# Resource allowlist: comma-separated AAD server app IDs and/or resource URLs.
# Default is the AKS AAD server app ID. To add ARM, for example:
#   ALLOWED_RESOURCES=6dae42f8-4368-4678-94ff-3960e28e3630,https://management.azure.com/
ALLOWED_RESOURCES=6dae42f8-4368-4678-94ff-3960e28e3630
# DEV ONLY (CLI: --allow-any-resource) — skips the resource allowlist:
# ALLOW_ANY_RESOURCE=1

# Subscription scoping.
# SUBSCRIPTION is passed to `az` for every mint; the allowlist (if set) restricts which effective subscription a caller may use.
# SUBSCRIPTION=00000000-0000-0000-0000-000000000000
# ALLOWED_SUBSCRIPTIONS=00000000-0000-0000-0000-000000000000,Prod-Sub

# --- Azure CLI identity ---
# AZURE_CONFIG_DIR=/var/lib/aad-bridge/.azure
AZURE_CONFIG_DIR=~/.azure
# AZ_PATH=az
# Pass --tenant from the request to az (single-tenant: leave off):
# AZ_PASS_TENANT=0

# --- Caching / lifecycle ---
# Refresh a cached token this many seconds before expiry:
REFRESH_SKEW_SECONDS=300
# Mint allowlisted resources this often to keep the refresh token warm (0=off):
KEEPALIVE_MINUTES=360
TOKEN_TIMEOUT_MS=60000

# --- Audit ---
# Path to the audit log. Leave this line commented out to log JSON to stdout/journald.
# AUDIT_LOG=/var/lib/aad-bridge/audit.log
